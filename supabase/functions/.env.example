# Copy this to supabase/functions/.env and fill in your values.
#
# IMPORTANT: this file is NOT auto-loaded. You must pass it explicitly:
#   supabase functions serve --env-file supabase/functions/.env
# Without --env-file, the functions run with no env vars and Google features
# will fail with "Google OAuth or Supabase not configured".
#
# Required for: get-google-auth-url, google-oauth-callback,
# get-google-access-token, picker-session-create, picker-session-poll.
# Use the same Google OAuth client as the web app + MCP.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be a host-accessible URL registered as an authorised redirect URI on the
# Google OAuth client. Inside the Supabase local Docker stack SUPABASE_URL is
# http://kong:8000 (Docker-internal), which Google rejects — so set this
# explicitly. For local dev: http://127.0.0.1:54321/functions/v1/google-oauth-callback
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:54321/functions/v1/google-oauth-callback
# Where the callback redirects the browser after storing tokens. Defaults to
# http://localhost:4321/dashboard if unset.
APP_OAUTH_REDIRECT_URL=http://localhost:4321/dashboard
# Browser-accessible base URL for storage public objects. Picker bytes are stored
# in the event-photos bucket and the URL we save in event_memories.photo_url is
# built from this base. Inside Docker SUPABASE_URL is http://kong:8000, which
# the browser can't resolve — so set this to a host-accessible URL.
STORAGE_PUBLIC_URL_BASE=http://127.0.0.1:54321
