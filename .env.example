# Plannen configuration — copy to .env and fill in.
#
# This file feeds two consumers:
#   1. The Vite dev server (only VITE_-prefixed vars reach the browser).
#   2. The MCP server / scripts / backend (load non-prefixed vars via dotenv).
#
# Section labels describe what the variable *does*, not which tier it belongs to,
# so they stay accurate across tier migrations. Bootstrap edits values in place.

# ── Tier selection ────────────────────────────────────────────────────────────
# 0 = embedded Postgres + Hono backend (default).
# 1 = local Supabase via Docker.
# 2 = Supabase Cloud (self-hosted).
PLANNEN_TIER=0
VITE_PLANNEN_TIER=0

# ── Plannen identity ──────────────────────────────────────────────────────────
# Email of the Plannen account this install operates as. Set by bootstrap.
PLANNEN_USER_EMAIL=

# ── Database ──────────────────────────────────────────────────────────────────
# Direct Postgres connection used by the MCP server (pg.Pool), migration runner,
# and seed scripts.
#   Tier 0: postgres://plannen:plannen@127.0.0.1:54322/plannen  (embedded pg)
#   Tier 1: postgres://postgres:postgres@127.0.0.1:54322/postgres  (local Supabase pg)
#   Tier 2: postgres://postgres.<ref>:<db-pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgres://plannen:plannen@127.0.0.1:54322/plannen

# ── Supabase ──────────────────────────────────────────────────────────────────
# Tier 0 ignores these. Tier 1 = http://127.0.0.1:54321 + local demo keys.
# Tier 2 = your cloud project URL + cloud anon/service keys.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
SUPABASE_PROJECT_REF=
# Browser-exposed copies (Vite only forwards VITE_-prefixed env vars).
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# ── Plannen backend (Tier 0 only) ─────────────────────────────────────────────
# The standalone Hono backend runs on Tier 0. Tier 1/2 use Supabase as the API.
PLANNEN_BACKEND_PORT=54323
BACKEND_URL=http://127.0.0.1:54323
VITE_PLANNEN_BACKEND_MODE=plannen-api

# ── MCP authentication (Tier 2 cloud MCP) ─────────────────────────────────────
# Bearer token bootstrap generates when deploying the cloud MCP edge function.
MCP_BEARER_TOKEN=

# ── Web app (Vercel, Tier 2) ──────────────────────────────────────────────────
# Production URL of the deployed web app. Used by `plannen status` to probe it.
# Leave unset on Tier 0/1; bootstrap sets it after `vercel deploy`.
PLANNEN_WEB_URL=

# ── Optional: Google Photos picker ────────────────────────────────────────────
# Leave blank to disable photo organisation. See README for OAuth setup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Photo storage backend ────────────────────────────────────────────────────
# One of: local-fs, supabase, s3.
#   - local-fs: Tier 0 only, writes under ~/.plannen/photos
#   - supabase: Tier 1/2 default, uses Supabase Storage's event-photos bucket
#   - s3:       Tier 1/2 opt-in, uses any S3-compatible bucket (R2/Tigris/B2/MinIO)
PLANNEN_STORAGE_BACKEND=supabase

# Required only when PLANNEN_STORAGE_BACKEND=s3:
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=plannen-photos
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://photos.example.com
# S3_FORCE_PATH_STYLE=false

# ── Optional: Audio transcription with whisper.cpp ────────────────────────────
# Path to whisper.cpp model file. Defaults to ~/.plannen/whisper/ggml-base.en.bin.
# Set to 'disabled' to opt out of audio transcription even if whisper-cli is installed.
PLANNEN_WHISPER_MODEL=
