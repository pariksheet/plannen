# Plannen configuration — copy to .env and fill in.
#
# This file feeds two consumers:
#   1. The Vite dev server (only VITE_-prefixed vars are exposed to the browser).
#   2. The MCP server, which loads non-prefixed vars via dotenv at startup.
#
# Tier 0 (embedded Postgres) is the default. Tier 1 (local Supabase) is opt-in.
# Bootstrap writes PLANNEN_TIER + the right DATABASE_URL or SUPABASE_* for the
# chosen tier; you usually don't need to edit by hand.

# ── Tier selection ────────────────────────────────────────────────────────────
PLANNEN_TIER=0

# ── Plannen identity ──────────────────────────────────────────────────────────
# Email of the Plannen account this install operates as. Set by bootstrap.
PLANNEN_USER_EMAIL=

# ── Tier 0: embedded Postgres ────────────────────────────────────────────────
# Used by the MCP server, migration runner, and (Phase 2) the backend.
DATABASE_URL=postgres://plannen:plannen@127.0.0.1:54322/plannen

# ── Tier 1: Local Supabase (optional — uncomment if PLANNEN_TIER=1) ──────────
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ── Optional: Google Photos picker ────────────────────────────────────────────
# Leave blank to disable photo organisation. See README for OAuth setup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional: Audio transcription with whisper.cpp ──────────────────────────────
# Path to whisper.cpp model file. Defaults to ~/.plannen/whisper/ggml-base.en.bin.
# Set to 'disabled' to opt out of audio transcription even if whisper-cli is installed.
PLANNEN_WHISPER_MODEL=
